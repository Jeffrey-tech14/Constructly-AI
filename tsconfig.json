{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "outDir": "./dist",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "rootDir": "src",
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": false,
    "target": "ES2020"
  },
  "include": [
    "src",
    "jtech-plan-api/payments/payment_verification.ts",
    "jtech-plan-api/payments/index.ts"
  ]
}