{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "outDir": "./dist",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "rootDir": "src",
    "skipLibCheck": true,
    "strict": false,
    "strictNullChecks": false,
    "target": "ES2020"
  },
  "include": [
    "src"
  ]
}